FACTORY_DEF * TeeFactory   FACTORY_NAME "$(BGT-processor_WORKSPACE_NAME)_Processed1738588922 Output Collector"   INPUT FEATURE_TYPE "$(BGT-processor_WORKSPACE_NAME)_AttributeExposer_OUTPUT"   INPUT FEATURE_TYPE "$(BGT-processor_WORKSPACE_NAME)_AttributeRemover_4_OUTPUT"   OUTPUT FEATURE_TYPE "$(BGT-processor_WORKSPACE_NAME)_Processed"
