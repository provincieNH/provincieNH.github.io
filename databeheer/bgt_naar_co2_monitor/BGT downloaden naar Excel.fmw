# Because @Count itself will evalute the expression to calculate the
# domain, we don't need to do anything in Tcl per feature going by
INCLUDE [    set domainPrefix {};    if { {Local} == {Local} }    {       set domainPrefix [FME_EncodeText {$(BGT-downloader_WORKSPACE_NAME)_Counter_2_}];    };    puts "MACRO $(BGT-downloader_WORKSPACE_NAME)_Counter_2_FULL_DOMAIN ${domainPrefix}@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>downloadRequestId<closeparen>,$(BGT-downloader_WORKSPACE_NAME)_Counter_2)"; ]
FACTORY_DEF {*} ExecuteFunctionFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_Counter_2_Rejector }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_TestFilter_5_Failure<space>when<space>receiving<space>data<space>from<space>the<space>peer"    FUNCTION_DEFINITION { @Count(REJECTABLE,fme_encoded,$($(BGT-downloader_WORKSPACE_NAME)_Counter_2_FULL_DOMAIN),"1") }    RESULT_ATTRIBUTE { "_count2" }    OUTPUT { COMPLETE FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Counter_2_OUTPUT"        }    OUTPUT { REJECTED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Counter_2_<REJECTED>"        }
