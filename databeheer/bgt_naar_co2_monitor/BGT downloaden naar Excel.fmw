FACTORY_DEF * TeeFactory    FACTORY_NAME $(BGT-downloader_WORKSPACE_NAME)_Reprojector    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_2DForcer_2D"    OUTPUT FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Reprojector_REPROJECTED"         @Reproject($($(BGT-downloader_WORKSPACE_NAME)_Reprojector_SOURCE),"EPSG:28992",NearestNeighbor,PreserveCells,$(BGT-downloader_WORKSPACE_NAME)_Reprojector,"COORD_SYS_WARNING",RASTER_TOLERANCE,0.0)
# -------------------------------------------------------------------------
# First determine which function we are going to be using -- we can do
# this statically at parse time for efficiency sake
MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function
INCLUDE [ if {{wkt} == {fmebinary} } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function @Geometry(TO_ATTRIBUTE_BINARY,"_geofilter") }           } elseif {{wkt} == {fmehex} } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function @Geometry(TO_ATTRIBUTE_BINARY_HEX,"_geofilter") }           } elseif {{wkt} == {fmexml} } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function @Geometry(TO_ATTRIBUTE,"_geofilter") }           } elseif {{wkt} == {polyline} } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function @Geometry(TO_ATTRIBUTE_POLYLINE,"_geofilter",<Unused>) }           } elseif {{wkt} == {wkt} } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function @OGCGeometry(to_attribute,wkt,"_geofilter",1.2,FLOAT_64) }           } elseif {{wkt} == {wkb} ||                     {wkt} == {wkbhex} } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function @OGCGeometry(to_attribute,wkt,"_geofilter",1.2) }           } elseif {{wkt} == {GEOJSON} ||                     {wkt} == {ESRIJSON} } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function @JSONGeometry(TO_ATTRIBUTE,wkt,"_geofilter",<Unused>) }           } elseif {{wkt} == {KML} } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function @KMLGeometry(TO_ATTRIBUTE,"_geofilter",<Unused>) }           } elseif {{wkt} == {GEORSS_SIMPLE} } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function @GeoRSSGeometry(TO_ATTRIBUTE,wkt,"_geofilter",<Unused>) }           } elseif {{wkt} == {GML_2.1.2} ||                     {wkt} == {GML_3.1.1} ||                     {wkt} == {GML_3.2.1} } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function @GMLGeometry(TO_ATTRIBUTE,wkt,"_geofilter",<Unused>,<Unused>,<Unused>,<Unused>) }           } elseif {{wkt} == {geohash} } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function @GeoHash(TO_ATTRIBUTE,"_geofilter",<Unused>) }           } elseif {{wkt} == {ogeosms} } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function @OGCGeometry(to_attribute,wkt,"_geofilter",<Unused>) }           } elseif {{wkt} == {geosms} ||                     {wkt} == {geo}    } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function @OGCGeometry(to_attribute,wkt,"_geofilter") }           } elseif {{wkt} == {mgrs} } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function @SupplyAttributes(_geofilter, @MGRS(TO_MGRS, <Unused>, <Unused>, "<Unused>")) }           } elseif {{wkt} == {mssql} } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function @SerializeGeometry(to_attribute,wkt,"_geofilter","<Unused>")}           } elseif {{wkt} == {iso6709} } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function @GeographicPoint(TO_ATTRIBUTE,"_geofilter","<Unused>","<Unused>")}           } elseif {{wkt} == {qlikmaps} } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function @Geometry(TO_ATTRIBUTE_QLIKMAPS_POLYLINE,"_geofilter",<Unused>) }           }         ]
# Next determine if we should remove the geometry and also do this once at parse time
# By default, the macro has nothing, meaning we do not remove. If we want to remove, then we'll set the macro to do so
MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_GeometryRemoveFunction
INCLUDE [ if {{No} == {Yes} } {               puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_GeometryRemoveFunction @RemoveGeometry() }           }         ]
FACTORY_DEF * TeeFactory    FACTORY_NAME $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Reprojector_REPROJECTED"    OUTPUT FEATURE_TYPE ___TOREJECTOR___         @RenameAttributes(FME_STRICT,___fme_rejection_code___,fme_rejection_code)         $($(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Function)         $($(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_GeometryRemoveFunction)
FACTORY_DEF * TestFactory    FACTORY_NAME $(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_Rejector    INPUT FEATURE_TYPE ___TOREJECTOR___    TEST @Value(fme_rejection_code) != ""    PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT    OUTPUT PASSED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_<REJECTED>"       @RemoveAttributes(___fme_rejection_code___)    OUTPUT FAILED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_OUTPUT"       @RenameAttributes(FME_STRICT,fme_rejection_code,___fme_rejection_code___)
# -------------------------------------------------------------------------
Tcl2 proc $(BGT-downloader_WORKSPACE_NAME)_ParameterFetcher_doFetch {} {    foreach {name val} {"_feature_types {$($(BGT-downloader_WORKSPACE_NAME)_feature_types$encode)} _date_delta {$($(BGT-downloader_WORKSPACE_NAME)_date_delta$encode)}"} {         if { [string match {*<at>*} $val] == 1 } {             set val [FME_Execute EvaluateExpression {STRING} $val {$(BGT-downloader_WORKSPACE_NAME)_ParameterFetcher}];         } elseif {[string match {*FME_CONDITIONAL*} $val] == 1} {             set val [FME_Execute EvaluateExpression {STRING} $val {$(BGT-downloader_WORKSPACE_NAME)_ParameterFetcher}];         } else {             set val [FME_DecodeTextOrAttr $val];         };       FME_SetAttribute [FME_DecodeText $name] $val    } }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_ParameterFetcher }    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_GeometryExtractor_OUTPUT"    OUTPUT { FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_ParameterFetcher_OUTPUT"         @Tcl2($(BGT-downloader_WORKSPACE_NAME)_ParameterFetcher_doFetch)          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} StringReplacerFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_StringReplacer }    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_ParameterFetcher_OUTPUT"    USE_REGEX { NO }    CASE_SENSITIVE { NO }    SOURCE_ATTRIBUTES { _feature_types }    FIND_TEXT { "<space>" }    REPLACE_TEXT { "<quote><comma><quote>" }    REPLACE_NO_MATCH { "_FME_NO_OP_" }    OUTPUT { OUTPUT FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_StringReplacer_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_TestFilter_INPUT }    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_StringReplacer_OUTPUT"    OUTPUT { FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_TestFilter_INPUTLINE }
FACTORY_DEF {*} TestFactory FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_TestFilter } INPUT FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_TestFilter_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_date_delta<closeparen>,$(BGT-downloader_WORKSPACE_NAME)_TestFilter) > @EvaluateExpression(FDIV,STRING_ENCODED,<at>DateTimeAdd<openparen><at>DateTimeNow<openparen><closeparen><comma>-P2D<closeparen>,$(BGT-downloader_WORKSPACE_NAME)_TestFilter) ENCODED } BOOLEAN_OPERATOR AND COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_0 FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_TestFilter_Delta<space>not<space>available<space>yet TEST_GROUP TEST { _date_delta ATTRIBUTE_HAS_A_VALUE "" ENCODED } TEST { @EvaluateExpression(FDIV,STRING_ENCODED,$($(BGT-downloader_WORKSPACE_NAME)_format),$(BGT-downloader_WORKSPACE_NAME)_TestFilter) = <quote>citygml<quote> ENCODED } BOOLEAN_OPERATOR AND COMPOSITE_TEST_EXPR "1 AND 2" OUTPUT PASSED_1 FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_TestFilter_Download<space>deltas OUTPUT FAILED FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_TestFilter_Full<space>download
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(BGT-downloader_WORKSPACE_NAME)_Logger_3_603a6510_5fe4_499d_977e_a34dd0d97aa64} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(BGT-downloader_WORKSPACE_NAME)_Logger_3
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_Logger_3_Logger }    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_TestFilter_Delta<space>not<space>available<space>yet"    OUTPUT { FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Logger_3_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>Selected<space>mutation<space>date<space>for<space>the<space>delta<space>download<space>is<space>newer<space>than<space>last<space>available<space>delta<space>download<space>from<space>the<space>API","20","20","",WARN,LOG_RECORD,$(FME_UUID_SAFE))                   }
