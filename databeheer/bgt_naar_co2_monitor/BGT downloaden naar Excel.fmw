FACTORY_DEF {$(INSTANCE_FILTERING)} TestFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_GeometryFilter_InstanceTest }    INPUT { FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_GeometryFilter___Input___ }    TEST @Geometry(IS_GEOMETRY_INSTANCE) == 1    OUTPUT { PASSED FEATURE_TYPE $(OUTPUT_INSTANCE_FTYPE) }    OUTPUT { FAILED FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_GeometryFilter___Input___ }
