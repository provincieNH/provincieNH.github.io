FACTORY_DEF * HTTPFactory    FACTORY_NAME $(BGT-downloader_WORKSPACE_NAME)_HTTPCaller_2       INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Requested_data"    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Decelerator_OUTPUT"    TARGET_URL "@EvaluateExpression(FDIV,STRING_ENCODED,$($(BGT-downloader_WORKSPACE_NAME)_domain)<at>Value<openparen>href_status<closeparen>,$(BGT-downloader_WORKSPACE_NAME)_HTTPCaller_2)"    HTTP_METHOD GET    SAVE_FILE NO    OUTPUT_FILENAME "<Unused>"    OUTPUT_DIRECTORY "<Unused>"    FILE_EXTENSION "<Unused>"    TARGET_ATTR "_response_body"    FILE_PATH_ATTR "<Unused>"    UPLOAD_FILE "<Unused>"    UPLOAD_BODY "<Unused>"    MULTIPART_UPLOAD <Unused>    UPLOAD_CONTENT_TYPE "<Unused>"    COMBINED_MULTIPART_TABLE    REQUEST_HEADER_TABLE    ADDITIONAL_URL_PARAMETERS    AUTH_USERNAME "<Unused>"    AUTH_PASSWORD "<Unused>"    AUTH_METHOD "<Unused>"    TARGET_ATTRIBUTE_ENCODING auto-detect    RESPONSE_HEADER_LIST_ATTR ""    STATUS_CODE_ATTR "_http_status_code"    ERROR_ATTR "_error"    CONNECTION_TIMEOUT_LENGTH 60    TRANSFER_TIMEOUT_LENGTH 90    FOLLOW_REDIRECTS Yes    VERIFY_SSL_CERTIFICATES Yes    NAMED_CONNECTION "<Unused>"    USE_COOKIES No    OUTPUT OUTPUT FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_HTTPCaller_2_Output"    OUTPUT REJECTED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_HTTPCaller_2_<REJECTED>"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_AttributeFilter }    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_HTTPCaller_2_Output"    OUTPUT { FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_AttributeFilter_FILTER }
FACTORY_DEF {*} AttributeFilterFactory FACTORY_NAME $(BGT-downloader_WORKSPACE_NAME)_AttributeFilter_Filter COMMAND_PARM_EVALUATION SINGLE_PASS INPUT FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_AttributeFilter_FILTER FILTER_ATTRIBUTE { _http_status_code } FILTER_VALUES { <lt>EMPTY<gt> <lt>MISSING<gt> <lt>NULL<gt> <lt>UNFILTERED<gt> 201 200 } PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT OUTPUT <lt>EMPTY<gt> FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_AttributeFilter_<lt>EMPTY<gt> OUTPUT <lt>MISSING<gt> FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_AttributeFilter_<lt>MISSING<gt> OUTPUT <lt>NULL<gt> FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_AttributeFilter_<lt>NULL<gt> OUTPUT <lt>UNFILTERED<gt> FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_AttributeFilter_<lt>UNFILTERED<gt> OUTPUT 201 FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_AttributeFilter_201 OUTPUT 200 FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_AttributeFilter_200
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(BGT-downloader_WORKSPACE_NAME)_AttributeFilter <lt>EMPTY<gt> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_AttributeFilter_<lt>EMPTY<gt>"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(BGT-downloader_WORKSPACE_NAME)_AttributeFilter <lt>MISSING<gt> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_AttributeFilter_<lt>MISSING<gt>"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(BGT-downloader_WORKSPACE_NAME)_AttributeFilter <lt>NULL<gt> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_AttributeFilter_<lt>NULL<gt>"
# -------------------------------------------------------------------------
# Create the DomainName that this transformer will use.
# Because @Count itself will evalute the expression to calculate the
# domain, we don't need to do anything in Tcl per feature going by
INCLUDE [    set domainPrefix {};    if { {Local} == {Local} }    {       set domainPrefix [FME_EncodeText {$(BGT-downloader_WORKSPACE_NAME)_Counter_}];    };    puts "MACRO $(BGT-downloader_WORKSPACE_NAME)_Counter_FULL_DOMAIN ${domainPrefix}@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>downloadRequestId<closeparen>,$(BGT-downloader_WORKSPACE_NAME)_Counter)"; ]
FACTORY_DEF {*} ExecuteFunctionFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_Counter_Rejector }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_AttributeFilter_200"    FUNCTION_DEFINITION { @Count(REJECTABLE,fme_encoded,$($(BGT-downloader_WORKSPACE_NAME)_Counter_FULL_DOMAIN),"1") }    RESULT_ATTRIBUTE { "_count" }    OUTPUT { COMPLETE FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Counter_OUTPUT"        }    OUTPUT { REJECTED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Counter_<REJECTED>"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_TestFilter_2_INPUT }    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Counter_OUTPUT"    OUTPUT { FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_TestFilter_2_INPUTLINE }
FACTORY_DEF {*} TestFactory FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_TestFilter_2 } INPUT FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_TestFilter_2_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_count<closeparen>,$(BGT-downloader_WORKSPACE_NAME)_TestFilter_2) < 1000 ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_0 FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_TestFilter_2_Continue OUTPUT FAILED FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_TestFilter_2_Abort
# -------------------------------------------------------------------------
# This is just a simple delay, which is given a # of seconds to stall
Tcl2 proc $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_delay {seconds unused} {     after [expr round($seconds * 1000)]; }
Tcl2 set $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_clockMillisecondsWhenLastFeatureWentBy [clock clicks -milliseconds];
# This proc ensures that no more than some maximum number of features get through each second
Tcl2 proc $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_maxpersecond {unused maxFeaturesPerSecond} {     global $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_clockMillisecondsWhenLastFeatureWentBy;     set minimumDelayInMilliseconds [expr 1000.0 / $maxFeaturesPerSecond];     set clockMillisecondsNow [clock clicks -milliseconds];     set milliSecondsSinceLastFeature [expr $clockMillisecondsNow -                    [set $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_clockMillisecondsWhenLastFeatureWentBy]];     if {$milliSecondsSinceLastFeature < $minimumDelayInMilliseconds} {         after [expr round($minimumDelayInMilliseconds - $milliSecondsSinceLastFeature)];     };     set $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_clockMillisecondsWhenLastFeatureWentBy [clock clicks -milliseconds]; }
# Now set up which of the above two delay procedures we'll actually
# use by renaming the one we want to "$(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_Waiter"
# Then that is what we'll actually call when a feature goes by.
Tcl2 if { {Per Feature Delay} == {Per Feature Delay} } {         rename $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_delay $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_Waiter;      } else {         rename $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_maxpersecond $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_Waiter;      };
INCLUDE [    if { ( {Per Feature Delay} == {Per Feature Delay} ) && ( {1} == {0} ) } {       puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_SPLITTER_OUTPUT "$(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_OUTPUT" };    } else {       puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_SPLITTER_OUTPUT $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2__toDelayRejector__};    } ]
FACTORY_DEF {*} FeatureTableSplitterFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2 }    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_TestFilter_2_Continue"    OUTPUT { FEATURES FEATURE_TYPE $($(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_SPLITTER_OUTPUT) }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_DelayRejector }    INPUT { FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2__toDelayRejector__ }    TEST { "1" TYPE NUM ENCODED }    TEST { PERFEATDELAY != PERFEATDELAY }    BOOLEAN_OPERATOR OR    OUTPUT { FAILED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_<REJECTED>"       fme_rejection_code "INVALID_PARAMETER_DELAY_PER_FEATURE"        }    OUTPUT { PASSED FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2__toMaximumRejector__ }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_MaximumRejector }    INPUT { FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2__toMaximumRejector__ }    TEST { "<Unused>" TYPE NUM ENCODED }    TEST { PERFEATDELAY != FEATPERSEC }    BOOLEAN_OPERATOR OR    OUTPUT { FAILED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_<REJECTED>"       fme_rejection_code "INVALID_PARAMETER_MAXIMUM_FEATURES_PER_SECOND"        }    OUTPUT { PASSED FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2__toOutput__ }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_Decelerator }    INPUT { FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_Decelerator_2__toOutput__ }    OUTPUT { FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_OUTPUT"         @Tcl2("$(BGT-downloader_WORKSPACE_NAME)_Decelerator_2_Waiter {1} {<Unused>}")          }
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(BGT-downloader_WORKSPACE_NAME)_Logger_666f226b_a50b_4187_9d8a_1e994362f1db4} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(BGT-downloader_WORKSPACE_NAME)_Logger
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_Logger_Logger }    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_TestFilter_2_Abort"    OUTPUT { FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Logger_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>data<space>preparation<space>took<space>more<space>than<space>1000<space>seconds","20","20","",ERROR,LOG_ONLY,$(FME_UUID_SAFE))                   }
