FACTORY_DEF * HTTPFactory    FACTORY_NAME $(BGT-downloader_WORKSPACE_NAME)_HTTPCaller_5       INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_TestFilter_Download<space>deltas"    TARGET_URL "https:<solidus><solidus>api.pdok.nl<solidus>lv<solidus>bgt<solidus>download<solidus>v1_0<solidus>delta?count=1000"    HTTP_METHOD GET    SAVE_FILE NO    OUTPUT_FILENAME "<Unused>"    OUTPUT_DIRECTORY "<Unused>"    FILE_EXTENSION "<Unused>"    TARGET_ATTR "_response_body"    FILE_PATH_ATTR "<Unused>"    UPLOAD_FILE "<Unused>"    UPLOAD_BODY "<Unused>"    MULTIPART_UPLOAD <Unused>    UPLOAD_CONTENT_TYPE "<Unused>"    COMBINED_MULTIPART_TABLE    REQUEST_HEADER_TABLE    ADDITIONAL_URL_PARAMETERS    AUTH_USERNAME "<Unused>"    AUTH_PASSWORD "<Unused>"    AUTH_METHOD "<Unused>"    TARGET_ATTRIBUTE_ENCODING auto-detect    RESPONSE_HEADER_LIST_ATTR ""    STATUS_CODE_ATTR "_http_status_code"    ERROR_ATTR "_error"    CONNECTION_TIMEOUT_LENGTH 60    TRANSFER_TIMEOUT_LENGTH 90    FOLLOW_REDIRECTS Yes    VERIFY_SSL_CERTIFICATES Yes    NAMED_CONNECTION "<Unused>"    USE_COOKIES No    OUTPUT OUTPUT FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_HTTPCaller_5_Output"    OUTPUT REJECTED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_HTTPCaller_5_<REJECTED>"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(BGT-downloader_WORKSPACE_NAME)_HTTPCaller_5 <REJECTED> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_HTTPCaller_5_<REJECTED>"
# -------------------------------------------------------------------------
FACTORY_DEF * JSONQueryFactory    FACTORY_NAME $(BGT-downloader_WORKSPACE_NAME)_JSONFragmenter    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_HTTPCaller_5_Output"    MODE EXPLODE    EXPLODE_FORMAT JSON    REJECT_EMPTY_LISTS YES    EXTRACT_ATTR Yes    JSON_ATTR "_response_body"    READ_FROM_FILE NO    FILEPATH_OR_URL "<Unused>"    OUTPUT_ATTRIBUTE "<Unused>"    EXPLODE_QUERY "json<openbracket><quote>deltas<quote><closebracket><openbracket>*<closebracket>"    RECURSIVE_FLATTEN YES    OUTPUT EXPLODED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_JSONFragmenter_FRAGMENTS"    OUTPUT REJECTED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_JSONFragmenter_<REJECTED>"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(BGT-downloader_WORKSPACE_NAME)_JSONFragmenter <REJECTED> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_JSONFragmenter_<REJECTED>"
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(BGT-downloader_WORKSPACE_NAME)_DateTimeConverter_c53698b9_8fff_4196_83ae_11fee9fcb8e74} ]
DEFAULT_MACRO $(BGT-downloader_WORKSPACE_NAME)_DateTimeConverter_EXPRESSION_LIST
INCLUDE [    set repairInput {};    if {{YES} eq {YES}} {       set repairInput "<comma>repair";    };    set inFormat {FME|ISO};    if { {} ne {} } {       set inFormat {};       if { [string first "<quote>" $inFormat] != -1 } {          set inFormat [string map {"<quote>" "<backslash><quote>"} $inFormat];       };    };    set outFormat {%Y%m%d%H%M%S};    if { [string first "<quote>" $outFormat] != -1 } {       set outFormat [string map {"<quote>" "<backslash><quote>"} $outFormat];    };    set parmList {};    set attrs {timeWindow.from};    foreach attr $attrs {       lappend parmList $attr;       set funcAttr $attr;       if { [string first "<quote>" $attr] != -1 }       {          set funcAttr [string map {"<quote>" "<backslash><quote>"} $attr];          append funcAttr "<quote>";          set funcAttr "<quote>$funcAttr";       };       lappend parmList <at>DateTimeFormat<openparen><at>DateTimeParse<openparen><at>Value<openparen>$funcAttr<closeparen><comma><quote>$inFormat<quote>$repairInput<closeparen><comma><quote>$outFormat<quote><closeparen>;    };    puts "MACRO $(BGT-downloader_WORKSPACE_NAME)_DateTimeConverter_EXPRESSION_LIST [join $parmList { }]"; ]
Tcl2 proc $(FME_UUID_SAFE)_DateTimeConverter {} {    set attrs {timeWindow.from};    set decodedAttrs {};    set attrVals {};    set attrNulls {};    set attrMissings {};    foreach attr $attrs {       set decodedAttr [FME_DecodeText $attr];       lappend decodedAttrs $decodedAttr;       lappend attrVals [FME_GetAttribute $decodedAttr];       lappend attrNulls [FME_IsAttributeNull $decodedAttr];       lappend attrExists [FME_AttributeExists $decodedAttr];    };    FME_Execute EvaluateExpression ATTR_CREATE_EXPR_PROPAGATE_MISSING_FDIV $($(BGT-downloader_WORKSPACE_NAME)_DateTimeConverter_EXPRESSION_LIST) $(BGT-downloader_WORKSPACE_NAME)_DateTimeConverter;    foreach attr $decodedAttrs oldAttrVal $attrVals oldAttrExists $attrExists oldAttrNull $attrNulls {       set newAttrVal [FME_GetAttribute $attr];       if {[string length $newAttrVal] == 0} {          if {{NO} eq {NO} || [string length $oldAttrVal] > 0} {             FME_SetAttribute fme_rejection_code "INVALID_INPUT";             break;          } elseif {!$oldAttrExists} {             FME_UnsetAttributes $attr;          } elseif {!$oldAttrNull} {             FME_SetAttribute $attr {};          };       }    }; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_DateTimeConverter_1 }    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_JSONFragmenter_FRAGMENTS"    OUTPUT { FEATURE_TYPE ___TOREJECTOR___       @RenameAttributes(FME_STRICT, ___fme_rejection_code___,fme_rejection_code)       @Tcl2($(FME_UUID_SAFE)_DateTimeConverter) }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_DateTimeConverter_Rejector }    INPUT FEATURE_TYPE ___TOREJECTOR___    TEST @Value(fme_rejection_code) != ""    PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT    OUTPUT { FAILED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_DateTimeConverter_OUTPUT"       @RenameAttributes(FME_STRICT, fme_rejection_code,___fme_rejection_code___)        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_TestFilter_11_INPUT }    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_DateTimeConverter_OUTPUT"    OUTPUT { FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_TestFilter_11_INPUTLINE }
FACTORY_DEF {*} TestFactory FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_TestFilter_11 } INPUT FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_TestFilter_11_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>timeWindow.from<closeparen>,$(BGT-downloader_WORKSPACE_NAME)_TestFilter_11) > @EvaluateExpression(FDIV,STRING_ENCODED,$($(BGT-downloader_WORKSPACE_NAME)_date_delta$encode),$(BGT-downloader_WORKSPACE_NAME)_TestFilter_11) ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_0 FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_TestFilter_11_new<space>delta<openparen>s<closeparen><space>available OUTPUT FAILED FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_TestFilter_11_<lt>UNFILTERED<gt>
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(BGT-downloader_WORKSPACE_NAME)_TestFilter_11 <lt>UNFILTERED<gt> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_TestFilter_11_<lt>UNFILTERED<gt>"
# -------------------------------------------------------------------------
# If we're doing LAST N features, then the multiplier comes in as 0.
# If we're doing First N, multiplier is -1.
# For RANDOM, we need to treat LAST N as if it was first N (i.e. have a -1)
# That is what the ? : does in the rate multiplier.
INCLUDE [ if { {-1} == {0} && {ORIGINAL} == {ORIGINAL} } {              puts "MACRO REAL_MODE LAST"; 	         puts "MACRO REAL_RATE 1"; 	      } else {              puts "MACRO REAL_MODE ORIGINAL";              puts "MACRO REAL_RATE [expr 1 * ( -1 ? -1 : -1 ) ]"; 	      } ]
FACTORY_DEF {*} SamplingFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_Sampler }    COMMAND_PARM_EVALUATION SINGLE_PASS    SAMPLE_RATE { $(REAL_RATE) }    SAMPLE_ORDER { $(REAL_MODE) }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_TestFilter_11_new<space>delta<openparen>s<closeparen><space>available"    OUTPUT { SAMPLED FEATURE_TYPE ___SAMPLED___ }
# This TeeFactory is needed because Sampler will still output features if it has no OUTPUT clauses specified.
# This way we behave nicely even if there are no output connections on the transformer. See PR#28886.
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_Sampler_Sampled }    INPUT FEATURE_TYPE ___SAMPLED___    OUTPUT { FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Sampler_SAMPLED"          }
