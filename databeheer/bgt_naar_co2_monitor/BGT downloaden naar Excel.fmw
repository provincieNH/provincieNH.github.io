FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_AttributeCreator_6 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Sampler_SAMPLED"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    ATTR_ACTION { "" "_request_body" "SET_TO" "<opencurly><lf><space><space><quote>featuretypes<quote>:<space><openbracket><quote><at>Value<openparen>_feature_types<closeparen><quote><lf><space><space><closebracket><comma><lf><space><space><quote>format<quote>:<space><quote>citygml<quote><comma><lf><space><space><quote>deltaId<quote>:<space><quote><at>Value<openparen>id<closeparen><quote><comma><lf><space><space><quote>geofilter<quote>:<space><quote><at>Value<openparen>_geofilter<closeparen><quote><lf><closecurly>" }      ATTR_ACTION { "" "_request_url" "SET_TO" "$($(BGT-downloader_WORKSPACE_NAME)_domain)<solidus>lv<solidus>bgt<solidus>download<solidus>v1_0<solidus>delta<solidus>custom" }    OUTPUT { OUTPUT FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_AttributeCreator_6_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_AttributeCreator_2 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_TestFilter_Full<space>download"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    ATTR_ACTION { "" "_request_body" "SET_TO" "<opencurly><lf><space><space><quote>featuretypes<quote>:<space><openbracket><quote><at>Value<openparen>_feature_types<closeparen><quote><lf><space><space><closebracket><comma><lf><space><space><quote>format<quote>:<space>$($(BGT-downloader_WORKSPACE_NAME)_format)<comma><lf><space><space><quote>geofilter<quote>:<space><quote><at>Value<openparen>_geofilter<closeparen><quote><lf><closecurly>" }      ATTR_ACTION { "" "_request_url" "SET_TO" "$($(BGT-downloader_WORKSPACE_NAME)_domain)<solidus>lv<solidus>bgt<solidus>download<solidus>v1_0<solidus>full<solidus>custom" }    OUTPUT { OUTPUT FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF * HTTPFactory    FACTORY_NAME $(BGT-downloader_WORKSPACE_NAME)_HTTPCaller       INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_AttributeCreator_6_OUTPUT"    TARGET_URL "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_request_url<closeparen>,$(BGT-downloader_WORKSPACE_NAME)_HTTPCaller)"    HTTP_METHOD POST    SAVE_FILE NO    OUTPUT_FILENAME "<Unused>"    OUTPUT_DIRECTORY "<Unused>"    FILE_EXTENSION "<Unused>"    TARGET_ATTR "_response_body"    FILE_PATH_ATTR "<Unused>"    UPLOAD_FILE "<Unused>"    UPLOAD_BODY "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_request_body<closeparen>,$(BGT-downloader_WORKSPACE_NAME)_HTTPCaller)"    MULTIPART_UPLOAD NO    UPLOAD_CONTENT_TYPE "application/json"    COMBINED_MULTIPART_TABLE    REQUEST_HEADER_TABLE    ADDITIONAL_URL_PARAMETERS    AUTH_USERNAME "<Unused>"    AUTH_PASSWORD "<Unused>"    AUTH_METHOD "<Unused>"    TARGET_ATTRIBUTE_ENCODING auto-detect    RESPONSE_HEADER_LIST_ATTR ""    STATUS_CODE_ATTR "_http_status_code"    ERROR_ATTR "_error"    CONNECTION_TIMEOUT_LENGTH 60    TRANSFER_TIMEOUT_LENGTH 90    FOLLOW_REDIRECTS Yes    VERIFY_SSL_CERTIFICATES Yes    NAMED_CONNECTION "<Unused>"    USE_COOKIES No    OUTPUT OUTPUT FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_HTTPCaller_Output"    OUTPUT REJECTED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_HTTPCaller_<REJECTED>"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_TestFilter_12_INPUT }    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_HTTPCaller_Output"    OUTPUT { FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_TestFilter_12_INPUTLINE }
FACTORY_DEF {*} TestFactory FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_TestFilter_12 } INPUT FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_TestFilter_12_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_http_status_code<closeparen>,$(BGT-downloader_WORKSPACE_NAME)_TestFilter_12) = 202 ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_0 FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_TestFilter_12_Success OUTPUT FAILED FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_TestFilter_12_Failure
# -------------------------------------------------------------------------
FACTORY_DEF * JSONQueryFactory    FACTORY_NAME $(BGT-downloader_WORKSPACE_NAME)_JSONExtractor    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_TestFilter_12_Success"    MODE EXTRACT    JSON_DOCUMENT "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_response_body<closeparen>,$(BGT-downloader_WORKSPACE_NAME)_JSONExtractor)"    READ_FROM_FILE NO    FILEPATH_OR_URL "<Unused>"    QUERIES href_status json<openbracket><quote>_links<quote><closebracket><openbracket><quote>status<quote><closebracket><openbracket><quote>href<quote><closebracket> downloadRequestId json<openbracket><quote>downloadRequestId<quote><closebracket>    OUTPUT EVALUATED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_JSONExtractor_EVALUATED"    OUTPUT REJECTED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_JSONExtractor_<REJECTED>"
# -------------------------------------------------------------------------
# This is just a simple delay, which is given a # of seconds to stall
Tcl2 proc $(BGT-downloader_WORKSPACE_NAME)_Decelerator_delay {seconds unused} {     after [expr round($seconds * 1000)]; }
Tcl2 set $(BGT-downloader_WORKSPACE_NAME)_Decelerator_clockMillisecondsWhenLastFeatureWentBy [clock clicks -milliseconds];
# This proc ensures that no more than some maximum number of features get through each second
Tcl2 proc $(BGT-downloader_WORKSPACE_NAME)_Decelerator_maxpersecond {unused maxFeaturesPerSecond} {     global $(BGT-downloader_WORKSPACE_NAME)_Decelerator_clockMillisecondsWhenLastFeatureWentBy;     set minimumDelayInMilliseconds [expr 1000.0 / $maxFeaturesPerSecond];     set clockMillisecondsNow [clock clicks -milliseconds];     set milliSecondsSinceLastFeature [expr $clockMillisecondsNow -                    [set $(BGT-downloader_WORKSPACE_NAME)_Decelerator_clockMillisecondsWhenLastFeatureWentBy]];     if {$milliSecondsSinceLastFeature < $minimumDelayInMilliseconds} {         after [expr round($minimumDelayInMilliseconds - $milliSecondsSinceLastFeature)];     };     set $(BGT-downloader_WORKSPACE_NAME)_Decelerator_clockMillisecondsWhenLastFeatureWentBy [clock clicks -milliseconds]; }
# Now set up which of the above two delay procedures we'll actually
# use by renaming the one we want to "$(BGT-downloader_WORKSPACE_NAME)_Decelerator_Waiter"
# Then that is what we'll actually call when a feature goes by.
Tcl2 if { {Per Feature Delay} == {Per Feature Delay} } {         rename $(BGT-downloader_WORKSPACE_NAME)_Decelerator_delay $(BGT-downloader_WORKSPACE_NAME)_Decelerator_Waiter;      } else {         rename $(BGT-downloader_WORKSPACE_NAME)_Decelerator_maxpersecond $(BGT-downloader_WORKSPACE_NAME)_Decelerator_Waiter;      };
INCLUDE [    if { ( {Per Feature Delay} == {Per Feature Delay} ) && ( {5} == {0} ) } {       puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_Decelerator_SPLITTER_OUTPUT "$(BGT-downloader_WORKSPACE_NAME)_Decelerator_OUTPUT" };    } else {       puts {MACRO $(BGT-downloader_WORKSPACE_NAME)_Decelerator_SPLITTER_OUTPUT $(BGT-downloader_WORKSPACE_NAME)_Decelerator__toDelayRejector__};    } ]
FACTORY_DEF {*} FeatureTableSplitterFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_Decelerator }    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_JSONExtractor_EVALUATED"    OUTPUT { FEATURES FEATURE_TYPE $($(BGT-downloader_WORKSPACE_NAME)_Decelerator_SPLITTER_OUTPUT) }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_Decelerator_DelayRejector }    INPUT { FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_Decelerator__toDelayRejector__ }    TEST { "5" TYPE NUM ENCODED }    TEST { PERFEATDELAY != PERFEATDELAY }    BOOLEAN_OPERATOR OR    OUTPUT { FAILED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Decelerator_<REJECTED>"       fme_rejection_code "INVALID_PARAMETER_DELAY_PER_FEATURE"        }    OUTPUT { PASSED FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_Decelerator__toMaximumRejector__ }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_Decelerator_MaximumRejector }    INPUT { FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_Decelerator__toMaximumRejector__ }    TEST { "<Unused>" TYPE NUM ENCODED }    TEST { PERFEATDELAY != FEATPERSEC }    BOOLEAN_OPERATOR OR    OUTPUT { FAILED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Decelerator_<REJECTED>"       fme_rejection_code "INVALID_PARAMETER_MAXIMUM_FEATURES_PER_SECOND"        }    OUTPUT { PASSED FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_Decelerator__toOutput__ }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BGT-downloader_WORKSPACE_NAME)_Decelerator_Decelerator }    INPUT { FEATURE_TYPE $(BGT-downloader_WORKSPACE_NAME)_Decelerator__toOutput__ }    OUTPUT { FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_Decelerator_OUTPUT"         @Tcl2("$(BGT-downloader_WORKSPACE_NAME)_Decelerator_Waiter {5} {<Unused>}")          }
