FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BGT-processor_WORKSPACE_NAME)_TestFilter_4_INPUT }    INPUT  FEATURE_TYPE "$(BGT-processor_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"    OUTPUT { FEATURE_TYPE $(BGT-processor_WORKSPACE_NAME)_TestFilter_4_INPUTLINE }
