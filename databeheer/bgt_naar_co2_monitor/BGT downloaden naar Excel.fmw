sed>" }    ATTR_CONFLICT_RES { "<Unused>" }    BASE_ATTR_PREFIX { "<Unused>" }    BOOLEAN_OPERATOR { OR }    REJECT_INVALID_GEOM Yes    REJECT_INVALID_PREDICATES Yes    REJECT_RASTERS No    ALLOW_NULLS Yes    CUSTOM_MULTI_HANDLING { Yes }    DIMENSION 2    FLUSH_WHEN_GROUPS_CHANGE { <Unused>  }    CURVE_BOUNDARY_RULE { ENDPOINTS_MOD2 }    OUTPUT { PASSED FEATURE_TYPE "$(BGT-processor_WORKSPACE_NAME)_SpatialFilter_3_PASSED"         }    OUTPUT { REJECTED FEATURE_TYPE "$(BGT-processor_WORKSPACE_NAME)_SpatialFilter_3_<REJECTED>"         }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(BGT-processor_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC }    } else {        puts "MACRO $(BGT-processor_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BGT-processor_WORKSPACE_NAME)_AttributeRemover_2 }    INPUT  FEATURE_TYPE "$(BGT-processor_WORKSPACE_NAME)_SpatialFilter_5_PASSED"    INPUT  FEATURE_TYPE "$(BGT-processor_WORKSPACE_NAME)_SpatialFilter_3_PASSED"    OUTPUT { FEATURE_TYPE "$(BGT-processor_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"        @RemoveAttributes(fme_encoded,path_extension,feature_type,path_filename,_matched_records,_InlezenWas,fme_rejection_code,_response_file_path,feature_type_test,path_rootname,_feature_types)        $($(BGT-processor_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC)         }
