FACTORY_DEF * JSONQueryFactory    FACTORY_NAME $(BGT-downloader_WORKSPACE_NAME)_JSONExtractor_2    INPUT  FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_AttributeFilter_201"    MODE EXTRACT    JSON_DOCUMENT "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_response_body<closeparen>,$(BGT-downloader_WORKSPACE_NAME)_JSONExtractor_2)"    READ_FROM_FILE NO    FILEPATH_OR_URL "<Unused>"    QUERIES href_download json<openbracket><quote>_links<quote><closebracket><openbracket><quote>download<quote><closebracket><openbracket><quote>href<quote><closebracket> progress json<openbracket><quote>progress<quote><closebracket> status json<openbracket><quote>status<quote><closebracket>    OUTPUT EVALUATED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_JSONExtractor_2_EVALUATED"    OUTPUT REJECTED FEATURE_TYPE "$(BGT-downloader_WORKSPACE_NAME)_JSONExtractor_2_<REJECTED>"
