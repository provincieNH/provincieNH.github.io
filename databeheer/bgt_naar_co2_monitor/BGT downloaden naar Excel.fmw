#!   FMX_ATTRIBUTE_PROPOGATION_MODE="AUTO"
#!   HISTORY="24-12-2021,Koen&lt;space&gt;Verhoeven&lt;space&gt;&lt;openparen&gt;Terralytics&lt;closeparen&gt;,v1.0&lt;space&gt;New&lt;space&gt;transformer&lt;space&gt;for&lt;space&gt;processing&lt;comma&gt;&lt;space&gt;separated&lt;space&gt;from&lt;space&gt;BGT-downloader,8-6-2022,Koen&lt;space&gt;Verhoeven&lt;space&gt;&lt;openparen&gt;Terralytics&lt;closeparen&gt;,v1.1&lt;space&gt;Changed&lt;space&gt;format&lt;space&gt;TestFilter&lt;space&gt;to&lt;space&gt;accept&lt;space&gt;xml&lt;space&gt;extension&lt;space&gt;for&lt;space&gt;deltas"
#!   IS_VISIBLE="true"
